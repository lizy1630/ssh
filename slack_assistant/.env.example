# --- Slack ---
# Bot token (xoxb-...) and app-level token (xapp-...) from your Slack app.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
# The dedicated inbox channel id the bot listens to (a private channel you made
# and invited the bot to, or the bot DM). A bot CANNOT read your personal self-DM.
INBOX_CHANNEL_ID=C0XXXXXXX
# Optional: only act on messages from this Slack user id (your id). Blank = any human.
ALLOWED_USER_ID=U0XXXXXXX

# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- MCP servers (Slack / Gmail / Google Calendar) ---
# Path to a JSON file in Claude Agent SDK mcp_servers format.
MCP_CONFIG_PATH=./mcp_servers.json

# --- Transcription (100% local; no cloud key needed) ---
# sensevoice (default) | paraformer | faster-whisper
TRANSCRIBE_PROVIDER=sensevoice

# --- Daily digest ---
DIGEST_HOUR=21
DIGEST_EMAIL_TO=lizy1630@gmail.com
DIGEST_EMAIL_SUBJECT=Day Summary

# --- Voice receiver (iPhone Back Tap -> Mac Mini) ---
# In production, bind to the Mac's Tailscale IP so the port is unreachable off-tailnet.
# Use 127.0.0.1 for local-only testing, or the 100.x.y.z Tailscale IP for the phone.
VOICE_API_HOST=127.0.0.1
VOICE_API_PORT=8765
# Channel that receives processed-voice results. Defaults to INBOX_CHANNEL_ID if unset.
SLACK_OUTPUT_CHANNEL=
MAX_UPLOAD_MB=25

# --- Health check ---
HEALTHCHECK_HOUR_INTERVAL=1
ALERT_EMAIL_TO=lizy1630@gmail.com
ALERT_EMAIL_SUBJECT=[ALERT] Slack assistant unhealthy
